# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (PostgreSQL)
# For Docker Compose setup, use: postgresql://postgres:password@localhost:5432/chatdb?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/chatdb?schema=public"

# Security (JWT)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRY="7d"

# CORS Configuration
CLIENT_URL="http://localhost:5173"

# Cloudinary Credentials (For Media Uploads)
# Leave these blank to use the local uploads folder fallback for testing
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Local Uploads Configuration (Fallback when Cloudinary is not configured)
UPLOAD_DIR="./uploads"

# Real AI Integration (Optional: Gemini / OpenAI API Key for Admin AI Auto-Reply)
GEMINI_API_KEY=""
OPENAI_API_KEY=""
