datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String         @id @default(uuid())
  username       String         @unique
  email          String         @unique
  passwordHash   String
  bio            String?        @default("Hey there! I am using ChatApp.")
  profilePicture String?        @default("https://res.cloudinary.com/demo/image/upload/v1312461204/sample.jpg")
  lastSeen       DateTime       @default(now())
  isOnline       Boolean        @default(false)
  status         String         @default("ONLINE") // "ONLINE", "AWAY", "BUSY", "OFFLINE"
  role           String         @default("USER") // "USER" or "ADMIN"
  isBanned       Boolean        @default(false)
  tokenVersion    Int            @default(1)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Conversations in which the user is participant 1 or 2
  conversationsAsUser1 Conversation[] @relation("User1Conversations")
  conversationsAsUser2 Conversation[] @relation("User2Conversations")

  // Messages sent by this user
  messagesSent         Message[]      @relation("SentMessages")
  
  // Reports made by or against this user
  reportsSubmitted     Report[]       @relation("SubmittedReports")
  reportsAgainst       Report[]       @relation("ReceivedReports")

  // Chat pinning (Local user pin metadata)
  pinnedConversations  PinnedChat[]

  // Calls
  callsMade            Call[]         @relation("CallsMade")
  callsReceived        Call[]         @relation("CallsReceived")
}

model Conversation {
  id             String       @id @default(uuid())
  user1Id        String
  user2Id        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user1          User         @relation("User1Conversations", fields: [user1Id], references: [id], onDelete: Cascade)
  user2          User         @relation("User2Conversations", fields: [user2Id], references: [id], onDelete: Cascade)
  
  messages       Message[]
  pinnedChats    PinnedChat[]
  calls          Call[]

  // Unique index to prevent duplicate 1-to-1 conversations between same two users
  @@unique([user1Id, user2Id])
  @@index([updatedAt(sort: Desc)])
  @@index([user1Id])
  @@index([user2Id])
}

model Message {
  id                   String        @id @default(uuid())
  conversationId       String
  senderId             String
  content              String?       
  type                 String        @default("TEXT") // "TEXT", "IMAGE", "VIDEO", "FILE", "VOICE"
  fileUrl              String?       // Cloudinary URL or local path
  fileName             String?       // Original name for PDFs/files
  fileSize             Int?          // Size in bytes
  filePublicId         String?       // Cloudinary public ID for deletions
  
  isDelivered          Boolean       @default(false)
  isSeen               Boolean       @default(false)
  isEdited             Boolean       @default(false)
  isDeletedForEveryone Boolean       @default(false)
  
  // SQLite Fallback: Store as a comma-separated string of user IDs, e.g. ",id1,id2,"
  deletedForUsers      String        @default("") 
  
  // Reply feature
  parentId             String?
  parentMessage        Message?      @relation("MessageReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies              Message[]     @relation("MessageReplies")

  // Reactions stored as Stringified JSON: { "userId": "emoji" }
  reactions            String        @default("{}")
  
  // Message pins
  isPinnedGlobally     Boolean       @default(false)

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  conversation         Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender               User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
}

model PinnedChat {
  id             String       @id @default(uuid())
  userId         String
  conversationId String
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}

model Report {
  id          String       @id @default(uuid())
  reporterId  String
  reportedId  String
  reason      String       
  status      String       @default("PENDING") // "PENDING" or "RESOLVED"
  createdAt   DateTime     @default(now())

  reporter    User         @relation("SubmittedReports", fields: [reporterId], references: [id], onDelete: Cascade)
  reported    User         @relation("ReceivedReports", fields: [reportedId], references: [id], onDelete: Cascade)
}

model Call {
  id          String   @id @default(uuid())
  callerId    String
  receiverId  String
  callType    String   // "VOICE" or "VIDEO"
  status      String   // "COMPLETED", "MISSED", "REJECTED", "BUSY", "FAILED"
  duration    Int      @default(0) // Duration in seconds
  startedAt   DateTime @default(now())
  endedAt     DateTime?

  caller      User     @relation("CallsMade", fields: [callerId], references: [id], onDelete: Cascade)
  receiver    User     @relation("CallsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String   // E.g., "BAN_USER", "TOGGLE_FEATURE_FLAG", "CLEAR_CACHE"
  targetType String?  // E.g., "USER", "REPORT", "SYSTEM"
  targetId   String?
  ipAddress  String?
  details    String?  // JSON string
  createdAt  DateTime @default(now())
}

model UserSession {
  id            String   @id @default(uuid())
  userId        String
  device        String?
  browser       String?
  os            String?
  ipAddress     String?
  country       String?
  isVpn         Boolean  @default(false)
  isDisposable  Boolean  @default(false)
  riskScore     Int      @default(0)
  isCurrentActive Boolean @default(true)
  lastActive    DateTime @default(now())
  createdAt     DateTime @default(now())
}

model IpRule {
  id        String   @id @default(uuid())
  ip        String   @unique
  type      String   // "BLACKLIST" or "WHITELIST"
  reason    String?
  addedBy   String?
  expiresAt DateTime?
  createdAt DateTime @default(now())
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  isEnabled   Boolean  @default(false)
  rules       String   @default("{}") // JSON string
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model IncidentAlert {
  id        String   @id @default(uuid())
  severity  String   // "CRITICAL", "WARNING", "INFO"
  type      String   // "DOWNTIME", "SECURITY", "SUSPICIOUS_LOGIN", "PAYMENT", "ERROR_RATE"
  title     String
  message   String
  metadata  String   @default("{}")
  isResolved Boolean @default(false)
  createdAt DateTime @default(now())
}

model AIModerationLog {
  id          String   @id @default(uuid())
  userId      String?
  messageId   String?
  contentType String   // "TEXT", "IMAGE", "ACCOUNT"
  flaggedCategories String // JSON array e.g., ["SPAM", "HATE_SPEECH"]
  riskScore   Int      @default(0)
  actionTaken String?  // "WARNING", "MUTE", "BAN", "NONE"
  reason      String?
  createdAt   DateTime @default(now())
}

model ApprovalRequest {
  id           String   @id @default(uuid())
  actionType   String   // "DELETE_USER", "PERMANENT_BAN", "FLUSH_DB"
  requestedBy  String
  approvedBy   String?
  targetId     String?
  payload      String   @default("{}")
  status       String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  createdAt    DateTime @default(now())
}

model UserStory {
  id             String   @id @default(uuid())
  userId         String
  username       String
  profilePicture String?
  text           String?
  mediaUrl       String?
  bgGradient     String   @default("from-indigo-600 to-purple-600")
  views          String   @default("[]") // JSON stringified array of user IDs
  createdAt      DateTime @default(now())
}

model InChatPoll {
  id          String   @id @default(uuid())
  pollId      String   @unique
  conversationId String
  question    String
  options     String   // JSON stringified array of options with votes
  isAnonymous Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
}

model StarredItem {
  id        String   @id @default(uuid())
  userId    String
  messageId String
  createdAt DateTime @default(now())

  @@unique([userId, messageId])
}


